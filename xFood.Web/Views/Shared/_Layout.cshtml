@{
    var user = Context.Session.GetString("UserName");
    var role = Context.Session.GetString("UserRole");
    bool isStaff = role == "Admin" || role == "Manager";
    bool isHomePage = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" &&
                      ViewContext.RouteData.Values["action"]?.ToString() == "Index";
    string navClass = isHomePage ? "aurum-navbar" : "aurum-navbar navbar-solid-state";
}
<!doctype html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Aurum Boulangerie — Patisserie</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Pinyon+Script&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

    <nav class="@navClass">
        <div class="container-fluid px-5">
            <div class="d-flex align-items-center justify-content-between position-relative" style="min-height: 80px;"> 

                <div class="d-flex align-items-center gap-4 nav-left">
                    <a href="/#menu-section" class="nav-item-link">Cardápio</a>
                    <a href="/#about" class="nav-item-link">A Maison</a>

                    <div class="d-flex align-items-center gap-2 ms-2 search-box"
                         style="cursor: pointer;"
                         data-bs-toggle="modal"
                         data-bs-target="#searchModal">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <span class="nav-item-link" style="font-size: 0.85rem;">Buscar</span>
                    </div>
                </div>

                <div class="logo-container text-center">
                    <a href="/" class="brand-main">AURUM BOULANGERIE</a>
                    <span class="brand-subtitle" style="font-family: 'Pinyon Script', cursive; font-size: 1.2rem; color: var(--gold-accent);">
                        São Paulo
                    </span>
                </div>

                <!-- TOGGLER MOBILE -->
                <button class="navbar-toggler-custom d-md-none"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mobileMenu"
                        aria-label="Abrir menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>



                <div class="d-flex align-items-center gap-4 justify-content-end nav-right">
                    @if (string.IsNullOrEmpty(user))
                    {
                        <a href="/Account/Login" class="icon-link" title="Área Restrita">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </a>
                    }
                    else
                    {
                        @if (isStaff)
                        {
                            <a href="/Admin" class="nav-item-link" style="color: var(--gold-accent) !important; border-bottom: 1px solid var(--gold-accent);">
                                PAINEL
                            </a>
                        }
                        <a href="/Account/Logout" class="icon-link" title="Sair do Sistema">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                        </a>
                    }
                    <a href="@Url.Action("Index", "Cart")" class="icon-link position-relative" title="Meu Pedido">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
                            <line x1="3" y1="6" x2="21" y2="6"></line>
                            <path d="M16 10a4 4 0 0 1-8 0"></path>
                        </svg>
                        <span class="badge-dot"></span>
                    </a>
                </div>
            </div>
        </div>

        <!-- MENU MOBILE -->
        <div class="collapse mobile-menu d-md-none" id="mobileMenu">
            <a href="/#menu-section" class="mobile-link">Cardápio</a>
            <a href="/#about" class="mobile-link">A Maison</a>

            <div class="mobile-link"
                 data-bs-toggle="modal"
                 data-bs-target="#searchModal">
                Buscar
            </div>

            <hr>

          

            @if (string.IsNullOrEmpty(user))
            {
                <a href="/Account/Login" class="mobile-link">Entrar</a>
            }
            else
            {
                @if (isStaff)
                {
                    <a href="/Admin" class="mobile-link">Painel</a>
                }
                <a href="/Account/Logout" class="mobile-link">Sair</a>
            }
        </div>

    </nav>



    <main>
        @RenderBody()
    </main>

    <footer class="footer-premium">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 text-center text-lg-start">
                    <div class="mb-4">
                        <h3 class="footer-brand-title">AURUM</h3>
                        <span class="footer-brand-subtitle">Boulangerie</span>
                    </div>
                    <p class="footer-text">
                        A verdadeira arte da panificação francesa no coração de São Paulo.
                        Momentos de sabor e elegância.
                    </p>
                </div>

                <div class="col-lg-4 text-center">
                    <h4 class="footer-heading">Contato</h4>
                    <p class="footer-text">Rua Oscar Freire, 1024 <br> Jardins, São Paulo - SP</p>
                    <p class="footer-text" style="color: var(--gold-accent); font-weight: 500;">(11) 99999-9999</p>
                </div>

                <div class="col-lg-4 text-center text-lg-end">
                    <h4 class="footer-heading">Social</h4>

                    <a href="#" class="footer-social-link" title="Instagram">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                    </a>

                    <a href="#" class="footer-social-link" title="WhatsApp">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
                    </a>
                </div>
            </div>

            <div class="text-center mt-5 pt-4 border-top border-secondary border-opacity-10">
                <small style="font-size: 0.75rem; color: #555;">&copy; @DateTime.Now.Year Aurum Boulangerie. Todos os direitos reservados.</small>
            </div>
        </div>
    </footer>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg" style="overflow: hidden;">
                <div class="modal-body p-4">

                    <div class="text-center mb-4">
                        <h4 style="font-family: 'Playfair Display', serif; color: #C5A059; letter-spacing: 1px;">
                            O que deseja saborear?
                        </h4>
                    </div>

                    <form action="/" method="get" class="position-relative">
                        <div class="input-group border-bottom border-secondary mb-2">
                            <span class="input-group-text bg-transparent border-0 ps-0">
                                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2">
                                    <circle cx="11" cy="11" r="8"></circle>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                </svg>
                            </span>

                            <input type="text" id="liveSearchInput" name="q"
                                   class="form-control border-0 bg-transparent shadow-none"
                                   placeholder="Ex: Croissant, Café..."
                                   autocomplete="off"
                                   style="font-family: 'Playfair Display', serif; font-style: italic;">

                            <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>

                        <div id="liveSearchResults" class="list-group mt-3 fade-in-up" style="display: none;">
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const input = document.getElementById('liveSearchInput');
            const resultsBox = document.getElementById('liveSearchResults');
            let timeout = null;

            input.addEventListener('keyup', function (e) {
                clearTimeout(timeout);
                const query = e.target.value;

                if (query.length < 2) {
                    resultsBox.style.display = 'none';
                    resultsBox.innerHTML = '';
                    return;
                }

                timeout = setTimeout(function () {
                    fetch('/Home/SearchJson?q=' + query)
                        .then(response => response.json())
                        .then(data => {
                            resultsBox.innerHTML = '';
                            if (data.length > 0) {
                                resultsBox.style.display = 'block';
                                data.forEach(item => {
                                    const imgHtml = item.image
                                        ? `<img src="${item.image}" class="search-thumb rounded" style="width:40px; height:40px; object-fit:cover; margin-right:15px;">`
                                        : `<div class="search-thumb d-flex align-items-center justify-content-center bg-dark text-muted rounded" style="width:40px; height:40px; margin-right:15px;"><small>IMG</small></div>`;

                                    // AQUI GERA O HTML DO ITEM (Menuinho)
                                    const html = `
                                        <a href="/?q=${item.name}#menu-section" class="list-group-item list-group-item-action d-flex align-items-center p-3 border-0 mb-1 rounded">
                                            ${imgHtml}
                                            <div>
                                                <h6 class="mb-0 fw-bold" style="font-family: 'Playfair Display', serif;">${item.name}</h6>
                                                <small class="text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">
                                                    ${item.category}
                                                </small>
                                            </div>
                                            <div class="ms-auto fw-bold search-price" ;">
                                                 ${item.price}
                                            </div>
                                        </a>
                                    `;
                                    resultsBox.innerHTML += html;
                                });
                            } else {
                                resultsBox.style.display = 'block';
                                resultsBox.innerHTML = `
                                    <div class="text-center py-4 text-muted">
                                        <small>Nenhum sabor encontrado...</small>
                                    </div>`;
                            }
                        });
                }, 300);
            });
        });

               

    </script>
</body>
</html>