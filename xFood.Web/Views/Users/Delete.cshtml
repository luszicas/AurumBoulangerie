@model xFood.Application.DTOs.UserDto
@{
    ViewData["Title"] = "Excluir Usuário";
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <a href="@Url.Action("Index")" class="btn-back-elegant mb-4">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Voltar para Lista
    </a>

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="premium-table-card text-center pb-5">

                <div class="mb-4 text-danger opacity-75">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="8.5" cy="7" r="4"></circle>
                        <line x1="18" y1="8" x2="23" y2="13"></line>
                        <line x1="23" y1="8" x2="18" y2="13"></line>
                    </svg>
                </div>

                <h2 class="h4 mb-3" style="font-family: 'Playfair Display', serif; color: var(--text-color);">
                    Remover Acesso?
                </h2>

                <p class="text-muted small mb-4 px-4">
                    Você está prestes a excluir permanentemente o registro deste colaborador.
                </p>

                <div class="bg-light p-4 rounded mb-4 mx-3 border">

                    <div class="rounded-circle bg-white d-flex align-items-center justify-content-center mx-auto mb-3 shadow-sm text-muted fw-bold border"
                         style="width: 60px; height: 60px; font-size: 1.5rem;">
                        @(Model.Name?.Length > 0 ? Model.Name.Substring(0, 1).ToUpper() : "?")
                    </div>

                    <h3 class="h5 mb-1" style="font-family: 'Playfair Display', serif;">@Model.Name</h3>
                    <p class="text-muted small mb-2">@Model.Email</p>

                    <span class="badge bg-white text-dark border fw-normal text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">
                        @Model.TypeUserDescription
                    </span>
                </div>

                <form asp-action="Delete" method="post" class="px-3">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <button class="btn btn-danger w-100 py-3 mb-3 text-uppercase" style="letter-spacing: 2px; font-size: 0.8rem; border-radius: 0;">
                        Confirmar Exclusão
                    </button>

                    <a href="@Url.Action("Index")" class="text-muted small text-decoration-none text-uppercase" style="letter-spacing: 1px;">
                        Cancelar
                    </a>
                </form>

            </div>
        </div>
    </div>
</div>