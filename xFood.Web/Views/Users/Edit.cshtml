@model xFood.Application.DTOs.UserCreateUpdateDto
@{
    ViewData["Title"] = "Editar Usuário";
    var types = (SelectList)ViewBag.TypeUsers;
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <a href="@Url.Action("Index")" class="btn-back-elegant mb-4">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Voltar para Lista
    </a>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5">
                <span class="text-uppercase text-muted small" style="letter-spacing: 2px;">Gestão de Acesso</span>
                <h2 class="display-6 font-serif text-light">Editar Colaborador</h2>
            </div>

            <div class="premium-table-card p-5">
                <form asp-action="Edit" asp-route-id="@ViewBag.UserId" method="post">
                    <input type="hidden" name="id" value="@ViewBag.UserId" />

                    <div asp-validation-summary="All" class="alert alert-danger border-0 mb-4" style="background: rgba(220, 53, 69, 0.1); color: #ff6b6b; display:none"></div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label text-uppercase small text-muted mb-1">Nome</label>
                            <input asp-for="Name" class="form-control form-control-dark" placeholder="Nome Completo" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase small text-muted mb-1">E-mail</label>
                            <input asp-for="Email" class="form-control form-control-dark" placeholder="email@aurum.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase small text-muted mb-1">Senha</label>
                            <input asp-for="Password" class="form-control form-control-dark" placeholder="(Deixe em branco para manter)" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase small text-muted mb-1">Nascimento</label>
                            <input asp-for="DateBirth" type="date" class="form-control form-control-dark" />
                            <span asp-validation-for="DateBirth" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label text-uppercase small text-muted mb-1">Perfil de Acesso</label>
                            <select asp-for="TypeUserId" asp-items="types" class="form-select form-control-dark"></select>
                            <span asp-validation-for="TypeUserId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check pt-4 ps-4">
                                <input asp-for="Active" class="form-check-input" style="background-color: var(--gold-accent); border-color: var(--gold-accent);" />
                                <label class="form-check-label small text-light" asp-for="Active">Conta Ativa</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 d-flex justify-content-between align-items-center pt-4 border-top border-secondary border-opacity-25">
                        <a class="text-muted small text-decoration-none text-uppercase hover-gold" href="@Url.Action("Index")">
                            Cancelar
                        </a>
                        <button class="btn btn-aurum px-5 shadow-sm">Salvar Alterações</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}