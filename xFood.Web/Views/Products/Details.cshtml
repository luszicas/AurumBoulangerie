@model xFood.Application.DTOs.ProductDto
@{
    ViewData["Title"] = "Detalhes - " + Model.Name;
    var role = Context.Session.GetString("UserRole");
    bool isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
    bool isManager = string.Equals(role, "Manager", StringComparison.OrdinalIgnoreCase);
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <div class="mb-4">
        <a href="@Url.Action("Index")" class="btn-back-elegant">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
            Voltar para o Catálogo
        </a>
    </div>

    <div class="premium-table-card p-0 overflow-hidden">
        <div class="row g-0">

            <div class="col-lg-6 bg-black d-flex align-items-center justify-content-center position-relative" style="min-height: 500px; border-right: 1px solid rgba(255,255,255,0.05);">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid w-100 h-100" style="object-fit: cover; opacity: 0.9;" />
                }
                else
                {
                    <div class="text-center text-muted opacity-50">
                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="mb-3">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                        <p class="small text-uppercase mb-0 letter-spacing-2">Sem Fotografia</p>
                    </div>
                }
            </div>

            <div class="col-lg-6 p-5 d-flex flex-column justify-content-center">

                <div class="mb-2">
                    <span class="text-uppercase small fw-bold" style="color: var(--gold-accent); letter-spacing: 2px;">
                        @Model.CategoryName
                    </span>
                </div>

                <h1 class="display-5 mb-3 text-light" style="font-family: 'Playfair Display', serif;">
                    @Model.Name
                </h1>

                <div class="mb-4">
                    <span class="display-6" style="color: var(--gold-accent); font-family: 'Playfair Display', serif;">
                        @Model.Price.ToString("C")
                    </span>
                </div>

                <div class="py-4 border-top border-bottom border-secondary border-opacity-10 mb-4">
                    <h4 class="h6 text-uppercase text-muted mb-3 small letter-spacing-1">Sobre este item</h4>
                    <p class="lead mb-0 text-light opacity-75" style="font-size: 1rem; line-height: 1.8; font-weight: 300;">
                        @(Model.Description ?? "Nenhuma descrição detalhada foi fornecida para este produto. Consulte o chef para mais informações.")
                    </p>
                </div>

                <div class="mb-5 d-flex align-items-center gap-3">
                    <span class="text-uppercase small text-muted letter-spacing-1">Disponibilidade:</span>

                    @if (Model.Stock > 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success fw-normal text-uppercase px-3 py-2 letter-spacing-1">
                            Em Estoque (@Model.Stock un.)
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger fw-normal text-uppercase px-3 py-2 letter-spacing-1">
                            Esgotado
                        </span>
                    }
                </div>

                <div class="d-flex gap-3 mt-auto">
                    @if (isAdmin || isManager)
                    {
                        <a class="btn btn-aurum px-4 shadow-sm" href="@Url.Action("Edit", new { id = Model.Id })">
                            Editar Produto
                        </a>
                    }

                    @if (isAdmin)
                    {
                        <a class="btn btn-outline-danger px-4 rounded-0 text-uppercase small d-flex align-items-center"
                           style="letter-spacing: 1px; font-size: 0.75rem;"
                           href="@Url.Action("Delete", new { id = Model.Id })">
                            Excluir Item
                        </a>
                    }
                </div>

            </div>
        </div>
    </div>
</div>