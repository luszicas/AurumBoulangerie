@model xFood.Application.DTOs.ProductCreateUpdateDto
@{
    ViewData["Title"] = "Novo Produto";
    var categories = (SelectList)ViewBag.Categories;
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <a href="@Url.Action("Index")" class="btn-back-elegant mb-4">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Voltar para Lista
    </a>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5">
                <span class="text-uppercase text-muted small" style="letter-spacing: 2px;">Gestão de Catálogo</span>
                <h2 class="display-6 font-serif text-light">Novo Item</h2>
            </div>

            <div class="premium-table-card p-5">

                <form method="post" enctype="multipart/form-data">

                    <div asp-validation-summary="All" class="alert alert-danger border-0 mb-4" style="background: rgba(220, 53, 69, 0.1); color: #ff6b6b; display:none"></div>

                    <div class="row g-4">

                        <div class="col-md-8">
                            <label class="form-label text-uppercase small text-muted mb-1">Nome do Produto</label>
                            <input asp-for="Name" class="form-control form-control-dark" placeholder="Ex: Croissant de Amêndoas" />
                            <span class="text-danger small" asp-validation-for="Name"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-uppercase small text-muted mb-1">Categoria</label>
                            <select asp-for="CategoryId" asp-items="categories" class="form-select form-control-dark">
                                <option value="" disabled selected>Selecione...</option>
                            </select>
                            <span class="text-danger small" asp-validation-for="CategoryId"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Price" class="form-label text-uppercase small text-muted mb-1">Preço (R$)</label>
                            <input asp-for="Price" class="form-control form-control-dark" type="text" inputmode="decimal" placeholder="0,00" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label text-uppercase small text-muted mb-1">Estoque Inicial</label>
                            <input asp-for="Stock" class="form-control form-control-dark" type="number" placeholder="0" />
                            <span class="text-danger small" asp-validation-for="Stock"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label text-uppercase small text-muted mb-1">Fotografia</label>
                            <input type="file" name="imageFile" class="form-control form-control-dark form-control-sm mt-1" accept="image/*"
                                   style="padding: 15px; border: 1px dashed rgba(255,255,255,0.2);" />

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mt-3 p-2 border border-secondary border-opacity-25 rounded d-inline-block bg-black">
                                    <img src="@Model.ImageUrl" class="img-fluid" style="max-height:100px; opacity: 0.8;" />
                                </div>
                            }
                        </div>

                        <div class="col-12">
                            <label class="form-label text-uppercase small text-muted mb-1">Descrição Detalhada</label>
                            <textarea asp-for="Description" class="form-control form-control-dark" rows="3" placeholder="Descreva os ingredientes e detalhes..."></textarea>
                        </div>

                    </div>

                    <div class="mt-5 d-flex justify-content-between align-items-center pt-4 border-top border-secondary border-opacity-25">
                        <a class="text-muted small text-decoration-none text-uppercase hover-gold" href="@Url.Action("Index")">
                            Cancelar
                        </a>
                        <button class="btn btn-aurum px-5 shadow-sm">
                            Salvar Produto
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}