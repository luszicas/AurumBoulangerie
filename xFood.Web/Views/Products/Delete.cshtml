@model xFood.Application.DTOs.ProductDto
@{
    ViewData["Title"] = "Excluir Produto";
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="premium-table-card text-center pb-5 pt-5">

                <div class="mb-4 text-danger opacity-75">
                    <svg width="50" height="50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                </div>

                <h2 class="h4 mb-3 text-light" style="font-family: 'Playfair Display', serif;">
                    Confirmar Remoção
                </h2>

                <p class="text-muted small mb-4 px-4">
                    Você está prestes a remover este item do catálogo permanentemente. Esta ação não pode ser desfeita.
                </p>

                <div class="p-4 rounded mb-4 mx-3 border border-secondary border-opacity-25" style="background-color: rgba(255,255,255,0.03);">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="rounded-circle shadow-lg mb-3 thumb-premium"
                             style="width: 80px; height: 80px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-black d-flex align-items-center justify-content-center mx-auto mb-3 border border-secondary border-opacity-25"
                             style="width: 80px; height: 80px;">
                            <span class="text-muted small">IMG</span>
                        </div>
                    }

                    <h3 class="h5 mb-1 text-light" style="font-family: 'Playfair Display', serif;">@Model.Name</h3>

                    <div class="d-flex justify-content-center gap-2 text-muted small text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">
                        <span>@Model.CategoryName</span>
                        <span>&bull;</span>
                        <span>Estoque: @Model.Stock</span>
                    </div>

                    <div class="mt-2" style="color: var(--gold-accent); font-weight: 600;">
                        @Model.Price.ToString("C")
                    </div>
                </div>

                <form method="post" class="px-3">
                    <input type="hidden" asp-for="Id" />

                    <button class="btn btn-outline-danger w-100 py-3 mb-3 text-uppercase hover-danger-fill"
                            style="letter-spacing: 2px; font-size: 0.8rem; border-radius: 2px;">
                        Sim, Excluir Produto
                    </button>

                    <a href="@Url.Action("Index")" class="text-muted small text-decoration-none text-uppercase hover-gold" style="letter-spacing: 1px;">
                        Cancelar e Voltar
                    </a>
                </form>

            </div>
        </div>
    </div>
</div>