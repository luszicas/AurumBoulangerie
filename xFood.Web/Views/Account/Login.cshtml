@{
    Layout = null;
    ViewData["Title"] = "Staff Login - Aurum";
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Staff Login - Aurum Boulangerie</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="body-login">
    <div class="login-wrapper">
        <div class="login-overlay"></div>

        <div class="login-card fade-in-up">
            <div class="mb-4">
                <h2>Staff Login</h2>
                <small class="text-uppercase">Aurum Boulangerie Management</small>
            </div>

            <form method="post" action="/Account/Login">

                <div class="mb-3 text-start">
                    <label class="form-label">E-mail Corporativo</label>
                    <input type="email" name="email" class="form-control" required placeholder="ex: chef@aurum.com" autocomplete="off" />
                </div>

                <div class="mb-4 text-start">
                    <label class="form-label">Senha de Acesso</label>
                    <input type="password" name="password" class="form-control" required placeholder="••••••" />
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert p-2 text-center mb-3" style="background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; color: #ff6b6b; font-size: 0.8rem;">
                        @ViewBag.Error
                    </div>
                }

                <div class="d-grid">
                    <button type="submit" class="btn-aurum">Acessar Sistema</button>
                </div>
            </form>

            <a href="/" class="back-link">← Voltar para a Boutique</a>
        </div>
    </div>

</body>
</html>