@model xFood.Application.DTOs.CategoryDto
@{
    ViewData["Title"] = "Nova Categoria";
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">
    <a href="@Url.Action("Index")" class="btn-back-elegant mb-4">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Voltar para Lista
    </a>


    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="text-center mb-5">
                <span class="text-uppercase text-muted small" style="letter-spacing: 2px;">Gestão de Menu</span>
                <h2 class="display-6" style="font-family: 'Playfair Display', serif; color: var(--text-color);">Nova Categoria</h2>
            </div>

            <div class="premium-table-card">
                <form method="post">

                    <div asp-validation-summary="All" class="text-danger mb-4 small border-start border-3 border-danger ps-3" style="display:none"></div>

                    <div class="mb-4">
                        <label class="form-label text-uppercase small text-muted">Nome da Seção</label>
                        <input asp-for="Name" class="form-control form-input-premium" placeholder="Ex: Boulangerie" />
                        <span class="text-danger small" asp-validation-for="Name"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-uppercase small text-muted">Descrição (Opcional)</label>
                        <textarea asp-for="Description" class="form-control form-input-premium" rows="3" placeholder="Breve descrição para o cardápio..."></textarea>
                        <span class="text-danger small" asp-validation-for="Description"></span>
                    </div>

                    <div class="mt-5 d-flex justify-content-between align-items-center">
                        <a class="text-muted small text-decoration-none text-uppercase" href="@Url.Action("Index")">
                            &larr; Cancelar
                        </a>
                        <button class="btn btn-aurum px-5">
                            Salvar Categoria
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}