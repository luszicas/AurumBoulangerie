@model xFood.Application.DTOs.CategoryDto
@{
    
    ViewData["Title"] = "Excluir Categoria";
    // Recupera a flag do Controller
    bool hasProducts = ViewBag.HasProducts is bool b && b;
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="premium-table-card text-center pb-5">

                @if (hasProducts)
                {
                    /* --- CENÁRIO A: BLOQUEADO (Tem Produtos) --- */
                    <div class="mb-4 text-warning opacity-75">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>

                    <h2 class="h4 mb-3" style="font-family: 'Playfair Display', serif; color: var(--text-color);">
                        Ação Bloqueada
                    </h2>

                    <p class="text-muted small mb-4 px-3">
                        A categoria <strong>@Model.Name</strong> possui produtos vinculados e não pode ser removida.
                        Remova os produtos primeiro ou mova-os para outra seção.
                    </p>

                    <a href="@Url.Action("Index")" class="btn btn-aurum w-100 py-3 text-uppercase">
                        Voltar para a Lista
                    </a>
                }
                else
                {
                    /* --- CENÁRIO B: PERMITIDO (Sem Produtos) --- */
                    <div class="mb-4 text-danger opacity-75">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <polyline points="3 6 5 6 21 6"></polyline>
                            <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                            <line x1="10" y1="11" x2="10" y2="17"></line>
                            <line x1="14" y1="11" x2="14" y2="17"></line>
                        </svg>
                    </div>

                    <h2 class="h4 mb-3" style="font-family: 'Playfair Display', serif; color: var(--text-color);">
                        Excluir Categoria?
                    </h2>

                    <p class="text-muted small mb-4 px-3">
                        Você tem certeza que deseja remover <strong>@Model.Name</strong>? Esta ação é irreversível.
                    </p>

                    <div class="bg-light p-3 rounded mb-4 mx-3 border">
                        <small class="text-uppercase text-muted d-block mb-1" style="font-size: 0.65rem;">Descrição</small>
                        <span class="fst-italic text-muted">@Model.Description</span>
                    </div>

                    <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" class="px-3">
                        <input type="hidden" asp-for="Id" />

                        <button class="btn btn-danger w-100 py-3 mb-3 text-uppercase" style="letter-spacing: 2px; font-size: 0.8rem; border-radius: 0;">
                            Confirmar Exclusão
                        </button>

                        <a href="@Url.Action("Index")" class="text-muted small text-decoration-none text-uppercase" style="letter-spacing: 1px;">
                            Cancelar
                        </a>
                    </form>
                }

            </div>
        </div>
    </div>
</div>