@model IEnumerable<xFood.Application.DTOs.CategoryDto>
@{
    ViewData["Title"] = "Categorias";
}

<div class="container" style="padding-top: 150px; padding-bottom: 80px;">

    <a href="/Admin" class="btn-back-elegant mb-3">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Painel
    </a>

    @* --- BLOCO DE MENSAGENS PREMIUM (AURUM STYLE) --- *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert"
             style="background-color: #e8f5e9; color: #2e7d32; border-left: 4px solid #2e7d32 !important;">
            <div class="d-flex align-items-center">
                @* Ícone de Check *@
                <svg class="me-2" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                <strong>Sucesso!</strong>&nbsp; @TempData["Success"]
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert"
             style="background-color: #ffebee; color: #c62828; border-left: 4px solid #c62828 !important;">
            <div class="d-flex align-items-center">
                @* Ícone de Erro *@
                <svg class="me-2" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="12"></line>
                    <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
                <strong>Atenção!</strong>&nbsp; @TempData["Error"]
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @* --- FIM DO BLOCO --- *@

    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <span class="text-uppercase text-muted small" style="letter-spacing: 2px;">Backoffice</span>
            <h2 class="display-6" style="font-family: 'Playfair Display', serif; color: var(--text-color);">Categorias</h2>
        </div>
        <a class="btn btn-aurum" href="@Url.Action("Create")">
            + Nova Categoria
        </a>
    </div>

    <div class="premium-table-card">
        <table class="table-aurum">
            <thead>
                <tr>
                    <th style="width: 30%;">Nome</th>
                    <th>Descrição</th>
                    <th class="text-end" style="width: 150px;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>
                            <strong style="color: var(--text-color); font-family: 'Playfair Display', serif; font-size: 1.1rem;">
                                @c.Name
                            </strong>
                        </td>

                        <td>
                            <span class="text-muted small">@c.Description</span>
                        </td>

                        <td class="text-end">
                            <div class="btn-group">
                                <a href="@Url.Action("Edit", new { id = c.Id })"
                                   class="btn btn-link p-1" title="Editar" style="color: var(--gold-accent);">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                </a>

                                <a href="@Url.Action("Delete", new { id = c.Id })"
                                   class="btn btn-link text-danger p-1" title="Excluir">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <p class="text-muted">Nenhuma categoria cadastrada.</p>
            </div>
        }
    </div>
</div>