@model xFood.Web.Models.ShoppingCartViewModel
@{
    ViewData["Title"] = "Pedido Confirmado";
    int orderNum = ViewBag.OrderNumber;
    string name = ViewBag.CustomerName;
}

<div class="container text-center" style="padding-top: 150px; padding-bottom: 100px;">

    <div class="mb-4 fade-in-up" style="color: var(--gold-accent);">
        <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
            <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
    </div>

    <h1 class="display-5 mb-3 text-light fade-in-up" style="font-family: 'Playfair Display', serif;">
        Merci, @name.
    </h1>
    <p class="lead text-muted mb-5 fade-in-up">
        É um prazer servir você. Já enviamos seu pedido para a cozinha.
    </p>

    <div class="row justify-content-center fade-in-up" style="animation-delay: 0.2s;">
        <div class="col-md-6 col-lg-5">
            <div class="checkout-card p-5">

                <span class="d-block text-uppercase text-muted small letter-spacing-2 mb-2">Pedido Nº</span>

                <span class="d-block display-2 fw-bold mb-4" style="font-family: 'Playfair Display', serif; color: var(--gold-accent);">
                    #@orderNum
                </span>

                <div class="alert-checkout py-4 mb-4">
                    <h4 class="h6 text-uppercase letter-spacing-2 mb-2 text-light">Acomode-se, @name</h4>
                    <p class="small text-muted mb-0">
                        Não é necessário levantar. Em breve levaremos sua experiência até sua mesa.
                    </p>
                </div>

                <div class="text-start border-top border-secondary border-opacity-25 pt-4">
                    <p class="small text-muted text-uppercase mb-3 letter-spacing-1">Resumo do Pedido:</p>
                    <ul class="list-unstyled mb-0">
                        @foreach (var item in Model.Items)
                        {
                            <li class="d-flex justify-content-between mb-2 small text-light opacity-75">
                                <span>@item.Quantity x @item.ProductName</span>
                            </li>
                        }
                    </ul>
                </div>

            </div>

            <div class="mt-5">
                <a href="@Url.Action("Index", "Home")" class="btn-new-order">
                    Fazer Novo Pedido
                </a>
            </div>
        </div>
    </div>
</div>